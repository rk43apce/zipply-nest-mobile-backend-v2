  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/otp/send",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "auth",
                "otp",
                "send"
              ]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"9876543210\",\n  \"otp\": \"1234\",\n  \"device_id\": \"device_uuid_123\",\n  \"device_meta\": {\n    \"device_name\": \"Samsung Galaxy S21\",\n    \"model\": \"SM-G991B\",\n    \"os\": \"Android 13\",\n    \"app_version\": \"2.1.0\",\n    \"screen_resolution\": \"1080x2400\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/otp/verify",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "auth",
                "otp",
                "verify"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rider_id\": \"{{rider_id}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/logout",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
