PORT=3000
NODE_ENV=development
OTP_IN_RESPONSE=false
DATABASE_URL=postgresql://vida:password@localhost:5433/vida_rider
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-secret-key-256-bit-minimum
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d
UPLOAD_DIR=./uploads
API_LOG_FILE=./logs/api-requests.jsonl
S3_BUCKET=vida-documents
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
DISPATCH_OFFER_DELIVERY_MODE=dual

# Razorpay - Payment Gateway
# Mock mode: when key starts with 'rzp_test_mock', all payments are simulated
RAZORPAY_KEY_ID=rzp_test_mock_key
RAZORPAY_KEY_SECRET=mock_secret_key_for_dev
RAZORPAY_WEBHOOK_SECRET=mock_webhook_secret
# Leave empty to run payout processor in mock mode
RAZORPAY_PAYOUT_API_KEY=
# Mock payout delay in ms (simulates network latency)
MOCK_PAYOUT_DELAY_MS=3000

FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_PROJECT_ID=zipply-prod
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
